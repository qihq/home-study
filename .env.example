# 在群晖 Container Manager 中将此路径映射到可备份的共享目录。
FAMILY_LEARNING_DATA_DIR=/volume1/family-learning
FAMILY_LEARNING_PORT=8000

# 只在 NAS 后端环境中设置，绝不填入前端或提交到 Git。
APP_MIMO_API_KEY=
APP_MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
APP_MIMO_TTS_MODEL=mimo-v2.5-tts
APP_MIMO_TTS_VOICE=Chloe
APP_MIMO_TTS_SPEED=1.0
